rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
        request.auth.token.email == 'khyratfarmdates@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId)
        && incoming().uid == userId
        && incoming().createdAt == request.time
        && incoming().rating == 0
        && incoming().reviewsCount == 0
        && incoming().trustLevel == 10
        && incoming().verificationStatus == 'none'
        && incoming().isVerified == false
        && incoming().isSeller == false
        && (!('isAdmin' in incoming()) || incoming().isAdmin == (request.auth.token.email == 'khyratfarmdates@gmail.com'));
      
      allow update: if (isOwner(userId) || isAdmin())
        && incoming().uid == userId
        && incoming().createdAt == existing().createdAt
        && (
          isAdmin() || (
            isOwner(userId) && (
              // Action: Basic Info
              incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'phoneNumber']) ||
              // Action: Become Seller
              incoming().diff(existing()).affectedKeys().hasOnly(['isSeller', 'bio', 'specialties', 'trustLevel']) ||
              // Action: Submit Verification
              incoming().diff(existing()).affectedKeys().hasOnly(['idNumber', 'idPhotoUrl', 'agreedToTerms', 'verificationStatus', 'trustLevel']) ||
              // Action: Rating update (from OrderRating component)
              incoming().diff(existing()).affectedKeys().hasOnly(['reviewsCount', 'rating', 'trustLevel']) ||
              // Action: Auto-admin for matching email (STRICT)
              (incoming().diff(existing()).affectedKeys().hasOnly(['isAdmin']) && request.auth.token.email == 'khyratfarmdates@gmail.com' && incoming().isAdmin == true)
            )
          )
        );
    }

    // --- Orders ---
    function isValidOrder(data) {
      return data.buyerId is string && data.sellerId is string
        && data.title is string && data.title.size() <= 100
        && data.amount is number && data.amount > 0
        && data.status in ['pending', 'escrowed', 'delivered', 'completed', 'disputed', 'cancelled'];
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (
        isOwner(existing().buyerId) || 
        isOwner(existing().sellerId) || 
        (existing().sellerEmail == request.auth.token.email) ||
        existing().visibility == 'public'
      );
      allow list: if isSignedIn() && (
        resource.data.buyerId == request.auth.uid || 
        resource.data.sellerId == request.auth.uid || 
        resource.data.sellerEmail == request.auth.token.email ||
        resource.data.visibility == 'public'
      );
      
      allow create: if isSignedIn() 
        && isValidOrder(incoming())
        && isOwner(incoming().buyerId)
        && incoming().status == 'pending'
        && incoming().createdAt == request.time;
        
      allow update: if isSignedIn() 
        && (
          isOwner(existing().buyerId) || 
          isOwner(existing().sellerId) ||
          (existing().sellerEmail == request.auth.token.email)
        )
        && (
          // Action: Seller claims order (sets their UID if sellerId was unknown/placeholder)
          (existing().sellerId == 'unknown' && incoming().sellerId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['sellerId', 'updatedAt'])) ||
          
          (isValidOrder(incoming()) && (
            // Action: Buyer actions
            (isOwner(existing().buyerId) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) 
              && (
                (existing().status == 'pending' && incoming().status == 'cancelled') ||
                (existing().status == 'delivered' && incoming().status == 'completed') ||
                (existing().status == 'escrowed' && incoming().status == 'disputed') ||
                (existing().status == 'delivered' && incoming().status == 'disputed')
              )
            ) ||
            // Action: Seller actions
            ((isOwner(existing().sellerId) || existing().sellerEmail == request.auth.token.email) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
              && (
                (existing().status == 'pending' && incoming().status == 'escrowed') ||
                (existing().status == 'escrowed' && incoming().status == 'delivered')
              )
            )
          ))
        );
    }

    // --- Messages ---
    match /orders/{orderId}/messages/{messageId} {
      function canChat(ordId) {
        let order = get(/databases/$(database)/documents/orders/$(ordId)).data;
        return order.buyerId == request.auth.uid || 
               order.sellerId == request.auth.uid || 
               order.sellerEmail == request.auth.token.email;
      }

      allow read: if isSignedIn() && canChat(orderId);
      allow create: if isSignedIn() 
        && incoming().senderId == request.auth.uid
        && incoming().orderId == orderId
        && canChat(orderId);
    }

    // --- Reviews ---
    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && incoming().reviewerId == request.auth.uid
        && get(/databases/$(database)/documents/orders/$(incoming().orderId)).data.status == 'completed'
        && (
           get(/databases/$(database)/documents/orders/$(incoming().orderId)).data.buyerId == request.auth.uid ||
           get(/databases/$(database)/documents/orders/$(incoming().orderId)).data.sellerId == request.auth.uid
        );
    }

    // --- Disputes ---
    match /disputes/{disputeId} {
      allow read: if isSignedIn() && (
        isOwner(existing().raisedById) || 
        get(/databases/$(database)/documents/orders/$(existing().orderId)).data.buyerId == request.auth.uid ||
        get(/databases/$(database)/documents/orders/$(existing().orderId)).data.sellerId == request.auth.uid
      );
      allow create: if isSignedIn()
        && incoming().raisedById == request.auth.uid
        && incoming().status == 'open'
        && get(/databases/$(database)/documents/orders/$(incoming().orderId)).data.status == 'disputed';
    }

    // --- Platform Feedback ---
    match /platform_feedback/{feedbackId} {
      allow read: if isAdmin() 
        || (resource.data.userId == request.auth.uid)
        || (resource.data.rating >= 4);
      allow create: if isSignedIn()
        && incoming().comment is string && incoming().comment.size() <= 2000
        && incoming().rating is number && incoming().rating >= 1 && incoming().rating <= 5
        && incoming().createdAt == request.time
        && incoming().userId == request.auth.uid;
    }

    // --- Notifications ---
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid 
        && incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
      allow create: if isSignedIn();
    }

    // --- Transactions ---
    match /transactions/{txId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
    }
  }
}
