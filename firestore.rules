rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
        ('email' in request.auth.token && request.auth.token.email == 'khyratfarmdates@gmail.com')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if true;
      allow list: if resource.data.isSeller == true || 
                    (isSignedIn() && isAdmin()) || 
                    (isSignedIn() && request.auth.uid == userId) ||
                    (request.query.limit <= 1 && request.query.filters.size() == 1 && 'referralCode' in request.query.filters[0]);
      allow create: if isOwner(userId)
        && incoming().uid == userId;
      
      allow update: if (isSignedIn() && (
          isOwner(userId) || 
          isAdmin() || 
          // Action: Reward Inviter (Allows an invitee to reward their inviter upon completion)
          (incoming().diff(existing()).affectedKeys().hasOnly(['freeFeeTransactions', 'updatedAt']) && incoming().freeFeeTransactions == existing().freeFeeTransactions + 1)
        ))
        && incoming().uid == userId
        && (
          isAdmin() || 
          (incoming().diff(existing()).affectedKeys().hasOnly(['freeFeeTransactions', 'updatedAt']) && incoming().freeFeeTransactions == existing().freeFeeTransactions + 1) ||
          (
            isOwner(userId) && (
              // Action: Basic Info
              incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'phoneNumber', 'updatedAt', 'isOnline', 'lastSeen']) ||
              // Action: Referral Code (for migration of old users)
              incoming().diff(existing()).affectedKeys().hasOnly(['referralCode', 'updatedAt']) ||
              // Action: Become Seller
              incoming().diff(existing()).affectedKeys().hasOnly(['isSeller', 'bio', 'specialties', 'trustLevel', 'updatedAt']) ||
              // Action: Performance Sync (Automation)
              incoming().diff(existing()).affectedKeys().hasOnly(['avgResponseTime', 'isFeatured', 'updatedAt']) ||
              // Action: Submit Verification
              incoming().diff(existing()).affectedKeys().hasOnly(['idNumber', 'phoneNumber', 'idPhotoUrl', 'agreedToTerms', 'verificationStatus', 'trustLevel', 'updatedAt']) ||
              // Action: Rating update (from OrderRating component)
              incoming().diff(existing()).affectedKeys().hasOnly(['reviewsCount', 'rating', 'trustLevel', 'updatedAt']) ||
              // Action: Referral reward consumption
              incoming().diff(existing()).affectedKeys().hasOnly(['freeFeeTransactions', 'updatedAt']) && incoming().freeFeeTransactions == existing().freeFeeTransactions - 1 ||
              // Action: Auto-admin for matching email (STRICT)
              (incoming().diff(existing()).affectedKeys().hasOnly(['isAdmin']) && ('email' in request.auth.token && request.auth.token.email == 'khyratfarmdates@gmail.com') && incoming().isAdmin == true)
            )
          )
        );
    }

    // --- Referrals ---
    match /referrals/{refId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.inviterId == request.auth.uid || resource.data.inviteeId == request.auth.uid);
      allow create: if isSignedIn() && incoming().inviteeId == request.auth.uid;
      allow update: if isSignedIn() && isAdmin();
    }

    // --- SMS Logs ---
    match /sms_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn(); // Allow apps to log sent SMS for debugging
    }

    // --- Orders ---
    function isValidOrder(data) {
      return data.buyerId is string && data.sellerId is string
        && data.title is string && data.title.size() <= 100
        && data.amount is number && data.amount > 0
        && data.status in ['pending', 'escrowed', 'delivered', 'completed', 'disputed', 'cancelled'];
    }

    match /orders/{orderId} {
      allow get: if (existing().visibility == 'public') || (isSignedIn() && (
        isAdmin() ||
        isOwner(existing().buyerId) || 
        isOwner(existing().sellerId) || 
        ('sellerEmail' in existing() && 'email' in request.auth.token && existing().sellerEmail == request.auth.token.email)
      ));
      allow list: if (resource.data.visibility == 'public') || (isSignedIn() && (
        isAdmin() ||
        resource.data.buyerId == request.auth.uid || 
        resource.data.sellerId == request.auth.uid || 
        ('sellerEmail' in resource.data && 'email' in request.auth.token && resource.data.sellerEmail == request.auth.token.email)
      ));
      
      allow create: if isSignedIn() 
        && isValidOrder(incoming())
        && isOwner(incoming().buyerId)
        && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBlocked != true)
        && incoming().status == 'pending'
        && incoming().createdAt == request.time;
        
      allow update: if isSignedIn() 
        && (
          isOwner(existing().buyerId) || 
          isOwner(existing().sellerId) ||
          ('sellerEmail' in existing() && 'email' in request.auth.token && existing().sellerEmail == request.auth.token.email)
        )
        && (
          // Action: Seller claims order (sets their UID if sellerId was unknown/placeholder)
          (existing().sellerId == 'unknown' && incoming().sellerId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['sellerId', 'updatedAt'])) ||
          
          (isValidOrder(incoming()) && (
            // Action: Buyer actions
            (isOwner(existing().buyerId) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) 
              && (
                (existing().status == 'pending' && incoming().status == 'cancelled') ||
                (existing().status == 'delivered' && incoming().status == 'completed') ||
                (existing().status == 'escrowed' && incoming().status == 'disputed') ||
                (existing().status == 'delivered' && incoming().status == 'disputed')
              )
            ) ||
            // Action: Seller actions
            ((isOwner(existing().sellerId) || ('sellerEmail' in existing() && 'email' in request.auth.token && existing().sellerEmail == request.auth.token.email)) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
              && (
                (existing().status == 'pending' && incoming().status == 'escrowed') ||
                (existing().status == 'escrowed' && incoming().status == 'delivered')
              )
            )
          ))
        );
    }

    // --- Messages ---
    function isValidMessage(data) {
      return data.senderId is string && data.senderId.size() <= 128
        && data.text is string && data.text.size() <= 1000
        && data.orderId is string;
    }

    match /orders/{orderId}/messages/{messageId} {
      function canChat(ordId) {
        let orderPath = /databases/$(database)/documents/orders/$(ordId);
        let hasOrder = exists(orderPath);
        return isAdmin() || (hasOrder && (
          get(orderPath).data.buyerId == request.auth.uid || 
          get(orderPath).data.sellerId == request.auth.uid || 
          ('sellerEmail' in get(orderPath).data && 'email' in request.auth.token && get(orderPath).data.sellerEmail == request.auth.token.email)
        ));
      }

      allow read: if isSignedIn() && canChat(orderId);
      allow create: if isSignedIn() 
        && isValidMessage(incoming())
        && incoming().senderId == request.auth.uid
        && incoming().orderId == orderId
        && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBlocked != true)
        && canChat(orderId);
    }

    // --- Reviews ---
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn()
        && incoming().reviewerId == request.auth.uid
        && get(/databases/$(database)/documents/orders/$(incoming().orderId)).data.status == 'completed'
        && (
           get(/databases/$(database)/documents/orders/$(incoming().orderId)).data.buyerId == request.auth.uid ||
           get(/databases/$(database)/documents/orders/$(incoming().orderId)).data.sellerId == request.auth.uid
        );
    }

    // --- Disputes ---
    match /disputes/{disputeId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        isOwner(existing().raisedById) || 
        get(/databases/$(database)/documents/orders/$(existing().orderId)).data.buyerId == request.auth.uid ||
        get(/databases/$(database)/documents/orders/$(existing().orderId)).data.sellerId == request.auth.uid
      );
      allow update: if isAdmin();
      allow create: if isSignedIn()
        && incoming().raisedById == request.auth.uid
        && incoming().status == 'open'
        && get(/databases/$(database)/documents/orders/$(incoming().orderId)).data.status == 'disputed';
    }

    // --- Platform Feedback ---
    match /platform_feedback/{feedbackId} {
      allow read: if true;
      allow create: if isSignedIn()
        && incoming().comment is string && incoming().comment.size() <= 2000
        && incoming().rating is number && incoming().rating >= 1 && incoming().rating <= 5
        && incoming().createdAt == request.time
        && incoming().userId == request.auth.uid;
    }

    // --- Notifications ---
    match /notifications/{notifId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid || resource.data.userId == 'ADMIN');
      allow update: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
      allow create: if isSignedIn();
    }

    // --- Services ---
    match /services/{serviceId} {
      allow read: if true;
      allow create: if isSignedIn() && isOwner(incoming().sellerId) && incoming().createdAt == request.time;
      allow update, delete: if isSignedIn() && (isAdmin() || isOwner(existing().sellerId));
    }

    // --- App Settings ---
    match /app_settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Transactions ---
    match /transactions/{txId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
    }
  }
}
