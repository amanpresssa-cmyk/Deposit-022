rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isOwnerByEmail(email) {
      return isSignedIn() && 'email' in request.auth.token && request.auth.token.email == email;
    }

    function isAdmin() {
      return isSignedIn() && (
        ('email' in request.auth.token && request.auth.token.email == 'khyratfarmdates@gmail.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true)
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if true;
      allow list: if (resource.data.get('isSeller', false) == true) || 
                    (isSignedIn() && (
                      isAdmin() ||
                      request.auth.uid == userId ||
                      resource.data.get('uid', '') == request.auth.uid
                    )) ||
                    // Search by email or phone for order creation
                    (request.query.limit <= 1 && (
                      'email' in resource.data || 
                      'phoneNumber' in resource.data || 
                      'referralCode' in resource.data ||
                      'userShortId' in resource.data
                    ));
      allow create: if isOwner(userId);
      
      allow update: if (isSignedIn() && (
          isOwner(userId) || 
          isAdmin() || 
          // Action: Reward Inviter (Allows an invitee to reward their inviter upon completion)
          (incoming().diff(existing()).affectedKeys().hasOnly(['freeFeeTransactions', 'updatedAt']) && 
           incoming().get('freeFeeTransactions', 0) == existing().get('freeFeeTransactions', 0) + 1)
        ));
    }

    // --- Orders ---
    function isValidOrder(data) {
      return data.get('buyerId', '') is string && data.get('sellerId', '') is string
        && data.get('title', '').size() <= 200
        && data.get('amount', 0) is number && data.get('amount', 0) > 0
        && data.get('status', 'pending') in ['pending', 'escrowed', 'delivered', 'completed', 'disputed', 'cancelled'];
    }

    match /orders/{orderId} {
      function isOrderParty() {
        return isSignedIn() && (
          existing().buyerId == request.auth.uid || 
          existing().sellerId == request.auth.uid ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('email', '') == existing().get('sellerEmail', 'N/A'))
        );
      }

      allow get: if (existing().get('visibility', 'private') == 'public') || isAdmin() || isOrderParty();
      allow list: if (resource.data.get('visibility', 'private') == 'public') || 
                    (isSignedIn() && (
                      isAdmin() ||
                      resource.data.buyerId == request.auth.uid || 
                      resource.data.sellerId == request.auth.uid ||
                      resource.data.get('sellerEmail', '') == request.auth.token.email
                    ));
      
      allow create: if isSignedIn() 
        && isValidOrder(incoming())
        && (isOwner(incoming().buyerId) || isOwner(incoming().sellerId) || isOwner(incoming().creatorId))
        && (!exists(/databases/$(database)/documents/users/$(request.auth.uid)) || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBlocked', false) != true)
        && incoming().status == 'pending'
        && incoming().createdAt == request.time;
        
      allow update: if (isAdmin() || (isSignedIn() && (
          isOwner(existing().buyerId) || 
          isOwner(existing().sellerId) ||
          ('sellerEmail' in existing() && isOwnerByEmail(existing().sellerEmail))
        )))
        && (
          isAdmin() || (
            // Action: Seller claims order (sets their UID if sellerId was unknown/placeholder)
            (existing().sellerId == 'unknown' && incoming().sellerId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['sellerId', 'updatedAt'])) ||
            
            (isValidOrder(incoming()) && (
              // Action: Buyer actions
              (isOwner(existing().buyerId) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) 
                && (
                  (existing().status == 'pending' && incoming().status == 'cancelled') ||
                  (existing().status == 'delivered' && incoming().status == 'completed') ||
                  (existing().status == 'escrowed' && incoming().status == 'disputed') ||
                  (existing().status == 'delivered' && incoming().status == 'disputed')
                )
              ) ||
              // Action: Seller actions
              ((isOwner(existing().sellerId) || ('sellerEmail' in existing() && isOwnerByEmail(existing().sellerEmail))) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
                && (
                  (existing().status == 'pending' && incoming().status == 'escrowed') ||
                  (existing().status == 'escrowed' && incoming().status == 'delivered')
                )
              )
            ))
          )
        );
    }

    // --- Messages ---
    function isValidMessage(data) {
      return data.senderId is string && data.senderId.size() <= 128
        && data.text is string && data.text.size() <= 1000
        && data.orderId is string;
    }

    match /orders/{orderId}/messages/{messageId} {
      function canChat(ordId) {
        let orderPath = /databases/$(database)/documents/orders/$(ordId);
        let hasOrder = exists(orderPath);
        return isAdmin() || (hasOrder && (
          get(orderPath).data.buyerId == request.auth.uid || 
          get(orderPath).data.sellerId == request.auth.uid || 
          ('sellerEmail' in get(orderPath).data && 'email' in request.auth.token && get(orderPath).data.sellerEmail == request.auth.token.email)
        ));
      }

      allow read: if isSignedIn() && canChat(orderId);
      allow create: if isSignedIn() 
        && isValidMessage(incoming())
        && incoming().senderId == request.auth.uid
        && incoming().orderId == orderId
        && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBlocked != true)
        && canChat(orderId);
    }

    // --- Reviews ---
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn()
        && incoming().reviewerId == request.auth.uid
        && get(/databases/$(database)/documents/orders/$(incoming().orderId)).data.status == 'completed'
        && (
           get(/databases/$(database)/documents/orders/$(incoming().orderId)).data.buyerId == request.auth.uid ||
           get(/databases/$(database)/documents/orders/$(incoming().orderId)).data.sellerId == request.auth.uid
        );
    }

    // --- Disputes ---
    match /disputes/{disputeId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        isOwner(existing().raisedById) || 
        get(/databases/$(database)/documents/orders/$(existing().orderId)).data.buyerId == request.auth.uid ||
        get(/databases/$(database)/documents/orders/$(existing().orderId)).data.sellerId == request.auth.uid
      );
      allow update: if isAdmin();
      allow create: if isSignedIn()
        && incoming().raisedById == request.auth.uid
        && incoming().status == 'open'
        && get(/databases/$(database)/documents/orders/$(incoming().orderId)).data.status == 'disputed';
    }

    // --- Platform Feedback ---
    match /platform_feedback/{feedbackId} {
      allow read: if true;
      allow create: if isSignedIn()
        && incoming().comment is string && incoming().comment.size() <= 2000
        && incoming().rating is number && incoming().rating >= 1 && incoming().rating <= 5
        && incoming().createdAt == request.time
        && incoming().userId == request.auth.uid;
    }

    // --- Notifications ---
    function isValidNotification(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.message is string && data.message.size() <= 2000
        && data.type in ['order_update', 'payment', 'dispute', 'system', 'settlement', 'message', 'emergency']
        && ('priority' in data ? data.priority in ['normal', 'urgent', 'settlement'] : true)
        && data.isRead == false
        && data.createdAt == request.time;
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        (resource.data.userId == 'ADMIN' && isAdmin())
      );
      allow update: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
      allow create: if isSignedIn() && isValidNotification(incoming());
    }

    // --- Services ---
    match /services/{serviceId} {
      allow read: if true;
      allow create: if isSignedIn() && isOwner(incoming().sellerId) && incoming().createdAt == request.time;
      allow update, delete: if isSignedIn() && (isAdmin() || isOwner(existing().sellerId));
    }

    // --- App Settings ---
    match /app_settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Transactions ---
    match /transactions/{txId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
    }

    // --- Fee Transfers (Geidea) ---
    match /fee_transfers/{transferId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // --- Support Tickets ---
    function isValidSupportTicket(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.type in ['complaint', 'inquiry', 'live_chat', 'technical']
        && data.category in ['general', 'payment', 'seller', 'technical', 'suggestion']
        && data.status in ['open', 'in_progress', 'waiting_for_user', 'resolved', 'closed']
        && data.createdAt == request.time;
    }

    match /support_tickets/{ticketId} {
      allow create: if isSignedIn() && isValidSupportTicket(incoming()) && incoming().userId == request.auth.uid;
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if (isAdmin() && incoming().diff(existing()).affectedKeys().hasAny(['status', 'priority', 'updatedAt'])) ||
                       (isSignedIn() && isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['updatedAt', 'lastMessagePreview', 'lastMessageSenderId', 'lastMessageAt']));
      
      match /messages/{messageId} {
        function isValidSupportMessage(data) {
          return data.ticketId == ticketId
            && data.senderId == request.auth.uid
            && data.senderRole in ['user', 'admin']
            && data.text is string && data.text.size() <= 2000
            && data.createdAt == request.time;
        }

        allow read: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid);
        allow create: if isSignedIn() && isValidSupportMessage(incoming()) && 
                        (isAdmin() || get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid);
      }
    }

    // --- System Logs ---
    match /system_logs/{logId} {
      allow read: if isAdmin();
      allow create: if true; // Always allow logging errors to assist support
    }
  }
}
