{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "photoURL": { "type": "string" },
        "isBlocked": { "type": "boolean" },
        "blockReason": { "type": "string" },
        "showSupportOnBlock": { "type": "boolean" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" },
        "isVerified": { "type": "boolean" },
        "isSeller": { "type": "boolean" },
        "bio": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "trustLevel": { "type": "number" },
        "verificationStatus": { "type": "string", "enum": ["none", "pending", "verified", "rejected"] },
        "idNumber": { "type": "string" },
        "idPhotoUrl": { "type": "string" },
        "isFeatured": { "type": "boolean" },
        "avgResponseTime": { "type": "string" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "freeFeeTransactions": { "type": "number" },
        "userShortId": { "type": "string" },
        "emailConsent": { "type": "boolean" },
        "pushNotificationsEnabled": { "type": "boolean" },
        "orderNotificationsEnabled": { "type": "boolean" },
        "systemAlertsEnabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Escrow transaction between buyer and seller",
      "type": "object",
      "properties": {
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "escrowed", "delivered", "completed", "disputed", "cancelled"] },
        "visibility": { "type": "string", "enum": ["public", "private"] },
        "category": { "type": "string" },
        "buyerRatingCompleted": { "type": "boolean" },
        "sellerRatingCompleted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["buyerId", "sellerId", "title", "amount", "status", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message for an order",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "senderId", "text", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "Rating and comment for a transaction",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "reviewerId": { "type": "string" },
        "revieweeId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "reviewerId", "revieweeId", "rating", "createdAt"]
    },
    "Dispute": {
      "title": "Dispute",
      "description": "Information about a disputed transaction",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "raisedById": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "resolved", "dismissed"] },
        "resolution": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "raisedById", "reason", "status", "createdAt"]
    },
    "PlatformFeedback": {
      "title": "Platform Feedback",
      "description": "User suggestions and ratings for the platform",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "comment": { "type": "string" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["comment", "rating", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System alerts for users",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["order_update", "payment", "dispute", "system", "settlement"] },
        "priority": { "type": "string", "enum": ["normal", "settlement", "urgent"] },
        "orderId": { "type": "string" },
        "isRead": { "type": "boolean" },
        "action": { 
          "type": "object",
          "properties": {
            "label": { "type": "string" },
            "url": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "type", "isRead", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial records for orders",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "amount": { "type": "number" },
        "fee": { "type": "number" },
        "netAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["escrowed", "completed", "refunded"] },
        "specialty": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "amount", "status", "createdAt"]
    },
    "Referral": {
      "title": "Referral",
      "description": "Information about user invitations",
      "type": "object",
      "properties": {
        "inviterId": { "type": "string" },
        "inviteeId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["inviterId", "inviteeId", "status", "createdAt"]
    },
    "SupportTicket": {
      "title": "Support Ticket",
      "description": "User request for support or assistance",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["complaint", "inquiry", "live_chat", "technical"] },
        "category": { "type": "string", "enum": ["general", "payment", "seller", "technical", "suggestion"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
        "status": { "type": "string", "enum": ["open", "in_progress", "waiting_for_user", "resolved", "closed"] },
        "lastMessagePreview": { "type": "string" },
        "lastMessageSenderId": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "type", "category", "status", "createdAt"]
    },
    "SupportMessage": {
      "title": "Support Message",
      "description": "Messages within a support ticket conversation",
      "type": "object",
      "properties": {
        "ticketId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderRole": { "type": "string", "enum": ["user", "admin"] },
        "text": { "type": "string" },
        "isInternal": { "type": "boolean" },
        "attachments": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ticketId", "senderId", "senderRole", "text", "createdAt"]
    },
    "SystemLog": {
      "title": "System Log",
      "description": "Technical logs and error records",
      "type": "object",
      "properties": {
        "error": { "type": "string" },
        "operationType": { "type": "string" },
        "path": { "type": "string" },
        "authInfo": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" },
        "severity": { "type": "string" },
        "userAgent": { "type": "string" },
        "url": { "type": "string" }
      },
      "required": ["error", "timestamp"]
    },
    "FeeTransfer": {
      "title": "Fee Transfer",
      "description": "Confirmation of platform fees transferred by Geidea",
      "type": "object",
      "properties": {
        "transferId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string" },
        "geideaReference": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "status", "createdAt"]
    },
    "AppSettings": {
      "title": "App Settings",
      "description": "Platform-wide configuration partitioned by document ID",
      "type": "object",
      "properties": {
        "hero_banner": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "subtitle": { "type": "string" },
            "gradientFrom": { "type": "string" },
            "gradientTo": { "type": "string" },
            "showUserCards": { "type": "boolean" },
            "trustMessages": { "type": "array", "items": { "type": "string" } }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "orders": {
      "schema": "Order",
      "description": "Collection of escrow orders"
    },
    "orders/{orderId}/messages": {
      "schema": "Message",
      "description": "Subcollection of chat messages for an order"
    },
    "reviews": {
      "schema": "Review",
      "description": "Collection of user reviews"
    },
    "disputes": {
      "schema": "Dispute",
      "description": "Collection of transaction disputes"
    },
    "platform_feedback": {
      "schema": "PlatformFeedback",
      "description": "User feedback about the platform"
    },
    "notifications": {
      "schema": "Notification",
      "description": "User notifications collection"
    },
    "transactions": {
      "schema": "Transaction",
      "description": "Financial audit log for escrow"
    },
    "referrals": {
      "schema": "Referral",
      "description": "User referral tracking"
    },
    "support_tickets": {
      "schema": "SupportTicket",
      "description": "Collection of support requests"
    },
    "support_tickets/{ticketId}/messages": {
      "schema": "SupportMessage",
      "description": "Threaded messages for a support ticket"
    },
    "system_logs": {
      "schema": "SystemLog",
      "description": "Technical error logs"
    },
    "fee_transfers": {
      "schema": "FeeTransfer",
      "description": "Log of confirmed platform fee payouts from Geidea"
    },
    "app_settings": {
      "schema": "AppSettings",
      "description": "Collection of system configuration documents (key-value structure)"
    }
  }
}
